{
    "manifest_version": 3,
    "name": "Better YouTube Studio",
    "version": "1.0.0",
    "description": "Professional toolkit that enhances your YouTube Studio experience.",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://studio.youtube.com/*",
        "https://www.youtube.com/*",
        "https://www.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "Better YouTube Studio",
        "default_icon": {
            "16": "icons/betterstudioLogo.png",
            "48": "icons/betterstudioLogo.png",
            "128": "icons/betterstudioLogo.png"
        }
    },
    "icons": {
        "16": "icons/betterstudioLogo.png",
        "48": "icons/betterstudioLogo.png",
        "128": "icons/betterstudioLogo.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://studio.youtube.com/*"
            ],
            "js": [
                "src/utils/storage.js",
                "src/utils/dom.js",
                "src/utils/i18n.js",
                "src/features/graphColors/graphColors.js",
                "src/features/shortcuts/shortcuts.js",
                "src/features/tooltip/tooltip.js",
                "src/features/currencyPicker/currencies.js",
                "src/features/currencyPicker/currencyPicker.js",
                "src/features/logoutGuard/logoutGuard.js",
                "src/content/main.js"
            ],
            "css": [
                "src/features/graphColors/graphColors.css",
                "src/features/currencyPicker/currencyPicker.css",
                "src/features/logoutGuard/logoutGuard.css"
            ],
            "run_at": "document_idle"
        },
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "src/utils/storage.js",
                "src/utils/i18n.js",
                "src/features/logoutGuard/logoutGuard.js",
                "src/features/collections/config.js",
                "src/features/collections/storage.js",
                "src/features/collections/observer.js",
                "src/features/collections/youtube-api.js",
                "src/features/collections/ui/modals.js",
                "src/features/collections/ui/global-modal.js",
                "src/features/collections/ui/masthead-button.js",
                "src/features/collections/channel-page.js",
                "src/features/collections/collections.js",
                "src/content/youtubeMain.js"
            ],
            "css": [
                "src/features/logoutGuard/logoutGuard.css",
                "src/features/collections/collections.css"
            ],
            "run_at": "document_idle"
        }
    ]
}
